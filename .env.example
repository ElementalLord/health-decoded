# Public Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Gemini credential. Never prefix this variable with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Optional server-only AI security overrides. Conservative defaults are used
# when these are omitted or invalid.
AI_REQUESTS_PER_MINUTE=10
AI_REQUESTS_PER_HOUR=40
AI_REQUESTS_PER_DAY=120
AI_NETWORK_REQUESTS_PER_MINUTE=30
AI_RAPID_REQUEST_INTERVAL_MS=750
AI_DUPLICATE_REQUEST_LIMIT=3
AI_DUPLICATE_WINDOW_MS=120000
AI_ABUSE_BLOCK_MS=30000
AI_GLOBAL_PROVIDER_CALLS_PER_MINUTE=200
AI_GLOBAL_PROVIDER_CALLS_PER_DAY=2000
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_COOLDOWN_MS=120000
AI_PROVIDER_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=700
